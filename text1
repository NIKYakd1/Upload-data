            async function exportToPDF() {
                showLoading('📄 در حال تولید PDF...');
                try {
                    if (typeof html2canvas === 'undefined') { showToast('❌ کتابخانه html2canvas بارگذاری نشده است.', 'error'); hideLoading(); return; }
                    const printHeader = document.getElementById('printHeader');
                    const originalDisplay = printHeader.style.display;
                    printHeader.style.display = 'block';
                    document.body.classList.add('pdf-capture-mode');
                    const appContainer = document.querySelector('.app-container');
                    const canvas = await html2canvas(appContainer, { scale: 2, useCORS: true, logging: false, windowWidth: appContainer.scrollWidth, windowHeight: appContainer.scrollHeight });
                    printHeader.style.display = originalDisplay;
                    document.body.classList.remove('pdf-capture-mode');
                    const { jsPDF } = window.jspdf;
                    const doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a3' });
                    const pageWidth = doc.internal.pageSize.getWidth();
                    const pageHeight = doc.internal.pageSize.getHeight();
                    const margin = 12;
                    const imgWidth = pageWidth - margin * 2;
                    const imgHeight = (canvas.height * imgWidth) / canvas.width;
                    let heightLeft = imgHeight;
                    let position = margin;
                    doc.addImage(canvas, 'PNG', margin, position, imgWidth, imgHeight);
                    heightLeft -= (pageHeight - margin * 2);
                    while (heightLeft > 0) {
                        position = margin - (imgHeight - heightLeft);
                        doc.addPage();
                        doc.addImage(canvas, 'PNG', margin, position, imgWidth, imgHeight);
                        heightLeft -= (pageHeight - margin * 2);
                    }
                    const prodDate = toPersianDateStr(currentProductionDate);
                    doc.save(گزارش_منوی_پروازی_${prodDate.replace(/\//g,'-')}.pdf);
                    hideLoading();
                    showToast('📄 PDF با موفقیت ذخیره شد.');
                } catch (e) {
                    document.body.classList.remove('pdf-capture-mode');
                    hideLoading();
                    showToast('❌ خطا در تولید PDF', 'error');
                }
            }

