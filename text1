            // Remaining session logic unchanged, preserved for full file.
            // ... (session and idle management)
            let sessionCheckIntervalId, heartbeatIntervalId, idleTimer, idleWarningTimer;
            let lastActivityTime = Date.now();
            let idleTimeoutDuration = 15 * 60 * 1000;
            let idleWarningShown = false;

            async function validateSession() {
                if (!currentUser || !currentUser.sessionId) return;
                try {
                    const res = await fetch(${API_BASE}/sessions/validate?sessionId=${currentUser.sessionId}&token=${encodeURIComponent(currentUser.token || '')});
                    if (!res.ok) { handleInvalidSession('نشست نامعتبر'); return; }
                    const data = await res.json();
                    if (data.valid === false || data.status === 'invalid') handleInvalidSession(data.reason || 'نشست منقضی شده است.');
                    else if (data.forceLogout) handleForceLogout('نشست شما توسط مدیر سیستم پایان یافته است.');
                    else if (data.multiLoginDetected) handleMultiLogin();
                    else if (data.accountDisabled) handleInvalidSession('حساب کاربری شما غیرفعال شده است.');
                    else if (data.terminatedByAdmin) handleForceLogout('نشست شما توسط مدیر سیستم پایان یافته است.');
                } catch (e) { console.warn('Session validation error', e); }
            }
            function handleInvalidSession(reason) { showSessionModal('نشست نامعتبر', reason, () => { performLogout(); }); stopAllMonitors(); }
            function handleForceLogout(message) { showSessionModal('خاتمه نشست', message, () => { performLogout(); }); stopAllMonitors(); }
            function handleMultiLogin() { showSessionModal('ورود همزمان', 'ورود دیگری برای این حساب شناسایی شد. نشست فعلی بسته خواهد شد.', () => { performLogout(); }); stopAllMonitors(); }
            function performLogout() { fetch(${API_BASE}/logout, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sessionId: currentUser.sessionId, username: currentUser.username }) }).catch(() => {}); localStorage.removeItem('currentUser'); window.location.href = 'login.html'; }
            function showSessionModal(title, body, onConfirm) {
                const overlay = document.createElement('div'); overlay.className = 'modal-overlay active';
                overlay.innerHTML = <div class="modal" style="text-align:center;"><h3>${title}</h3><p style="margin:16px 0;">${body}</p><div class="actions" style="justify-content:center;"><button class="btn-primary" id="sessionModalConfirm">تأیید</button></div></div>;
                document.body.appendChild(overlay);
                document.getElementById('sessionModalConfirm').onclick = () => { overlay.remove(); if (onConfirm) onConfirm(); };
            }
            function stopAllMonitors() { clearInterval(sessionCheckIntervalId); clearInterval(heartbeatIntervalId); clearTimeout(idleTimer); clearTimeout(idleWarningTimer); }
            async function sendHeartbeat() {
                if (!currentUser) return;
                try { await fetch(${API_BASE}/heartbeat, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username: currentUser.username, userId: currentUser.id || '', companyId: currentUser.companyId || '', companyName: currentUser.companyName || '', sessionId: currentUser.sessionId, currentPage: window.location.pathname, lastActivity: new Date(lastActivityTime).toISOString(), onlineStatus: 'online' }) }); } catch (e) {}
            }
            function trackActivity() { lastActivityTime = Date.now(); if (idleWarningShown) dismissIdleWarning(); resetIdleTimer(); }
            function resetIdleTimer() { clearTimeout(idleTimer); clearTimeout(idleWarningTimer); idleWarningShown = false; idleWarningTimer = setTimeout(() => { showIdleWarning(); }, idleTimeoutDuration - 30000); idleTimer = setTimeout(() => { performLogout(); }, idleTimeoutDuration); }
            function showIdleWarning() {
                idleWarningShown = true;
                showSessionModal('هشدار عدم فعالیت', 'شما برای مدت طولانی غیرفعال بوده‌اید. در صورت عدم فعالیت، به‌طور خودکار خارج خواهید شد.<br><span id="idleCountdown" style="font-size:1.5rem;font-weight:bold;">۳۰</span> ثانیه', null);
                let count = 30; const countdownEl = document.getElementById('idleCountdown');
                window.idleCountdownInterval = setInterval(() => { count--; if (countdownEl) countdownEl.textContent = toPersianDigits(count); if (count <= 0) { clearInterval(window.idleCountdownInterval); performLogout(); } }, 1000);
                document.addEventListener('mousemove', dismissIdleWarning); document.addEventListener('keydown', dismissIdleWarning); document.addEventListener('click', dismissIdleWarning); document.addEventListener('touchstart', dismissIdleWarning);
            }
            function dismissIdleWarning() {
                if (idleWarningShown) { clearInterval(window.idleCountdownInterval); idleWarningShown = false; const overlay = document.querySelector('.modal-overlay.active'); if (overlay) overlay.remove(); document.removeEventListener('mousemove', dismissIdleWarning); document.removeEventListener('keydown', dismissIdleWarning); document.removeEventListener('click', dismissIdleWarning); document.removeEventListener('touchstart', dismissIdleWarning); trackActivity(); }
            }
            async function loadConfig() { try { const res = await fetch(${API_BASE}/config); if (res.ok) { const config = await res.json(); if (config.idleTimeoutMinutes && !isNaN(config.idleTimeoutMinutes)) { idleTimeoutDuration = config.idleTimeoutMinutes * 60 * 1000; resetIdleTimer(); } } } catch (e) {} }
            function setupActivityListeners() { ['mousemove','keydown','click','touchstart'].forEach(ev => { document.addEventListener(ev, trackActivity, { passive: true }); }); }
            function startMonitors() { validateSession(); sendHeartbeat(); resetIdleTimer(); sessionCheckIntervalId = setInterval(validateSession, 15000); heartbeatIntervalId = setInterval(sendHeartbeat, 30000); }
            setupActivityListeners(); loadConfig().then(() => { startMonitors(); });

            window.addEventListener('beforeunload', function(e) { if (hasUnsavedChanges) { e.preventDefault(); e.returnValue = 'شما تغییرات ذخیره نشده دارید. آیا مایل به خروج بدون ذخیره‌سازی هستید؟'; return e.returnValue; } });
