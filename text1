    <script>
        (function() {
            const API_BASE = 'http://localhost:9000';
            const currentUser = (() => {
                try {
                    const stored = localStorage.getItem('currentUser');
                    if (!stored) return null;
                    const user = JSON.parse(stored);
                    if (!user || !user.username) return null;
                    return user;
                } catch (e) { return null; }
            })();

            if (!currentUser || !currentUser.username) {
                alert('⛔ دسترسی غیرمجاز. لطفاً وارد شوید.');
                window.location.href = 'login.html';
                return;
            }

            const currentUsername = currentUser.username;

            document.getElementById('displayFullName').textContent = currentUser.fullName || '---';
            document.getElementById('displayUsername').textContent = currentUsername;
            document.getElementById('displayCompanyName').textContent = currentUser.companyName || '---';
            document.getElementById('displayCompanyId').textContent = currentUser.companyId || '---';
            document.getElementById('displayRole').textContent = getRoleDisplayName(currentUser.role);

            function getRoleDisplayName(role) {
                const roleMap = {
                    'admin': 'مدیر سیستم',
                    'manager': 'مدیر',
                    'supervisor': 'سرپرست',
                    'chef': 'سرآشپز',
                    'staff': 'کارمند',
                    'operator': 'اپراتور',
                    'viewer': 'ناظر',
                    'user': 'کاربر'
                };
                return roleMap[role] || role || 'کاربر';
            }

            let menuDatabase = null;
            let hasUnsavedChanges = false;
            let unsavedStats = { editedRows: new Set(), addedRows: 0, deletedRows: 0 };

            // Keep original snapshot to detect changes
            let originalMenuData = [];
            let originalCountsMap = {};

            function markUnsaved() { hasUnsavedChanges = true; }
            function clearUnsaved() { 
                hasUnsavedChanges = false; 
                unsavedStats.editedRows.clear();
                unsavedStats.addedRows = 0;
                unsavedStats.deletedRows = 0;
                // Update originals after saving
                originalMenuData = JSON.parse(JSON.stringify(currentMenuData));
                originalCountsMap = { ...currentCountsMap };
            }

            function escapeHtml(text) {
                if (text == null) return '';
                return String(text)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function toPersianDigits(input) {
                if (input == null) return '';
                return String(input).replace(/[0-9]/g, function(d) {
                    return String.fromCharCode(d.charCodeAt(0) + 1728);
                });
            }

            function toEnglishDigits(input) {
                if (input == null) return '';
                const persianDigits = '۰۱۲۳۴۵۶۷۸۹';
                let result = '';
                for (let ch of String(input)) {
                    const idx = persianDigits.indexOf(ch);
                    if (idx >= 0) result += idx;
                    else result += ch;
                }
                return result;
            }

            // Fallback to local template if server fails
            async function loadBaseTemplate() {
                try {
                    const response = await fetch('DataMn.json');
                    if (!response.ok) throw new Error('DataMn.json not found');
                    const json = await response.json();
                    if (!json || !Array.isArray(json.menuItems)) throw new Error('Invalid JSON format');
                    return json;
                } catch (err) {
                    showToast('❌ بارگذاری قالب پایه ناموفق بود.', 'error');
                    throw err;
                }
            }

            // Load from GET /menu (server API)
            async function loadUserMenuData() {
                try {
                    console.log([API] GET ${API_BASE}/menu);
                    const res = await fetch(${API_BASE}/menu);
                    if (res.ok) {
                        const data = await res.json();
                        console.log('[API] GET /menu response:', data);
                        if (data && Array.isArray(data)) {
                            // server returns array of items, reconstruct counts and customColumns from items
                            const menuItems = data.map(item => {
                                const { count, ...rest } = item;
                                return rest;
                            });
                            const counts = {};
                            data.forEach(item => {
                                if (item.serviceNameId && typeof item.count === 'number') {
                                    counts[item.serviceNameId] = item.count;
                                }
                            });
                            // customColumns not persisted via /menu, keep from localStorage
                            const savedCC = loadFromLS('customColumns', []);
                            return { menuItems, counts, customColumns: savedCC };
                        } else if (data && data.menuItems) {
                            // fallback if server returns wrapped object
                            return {
                                menuItems: data.menuItems,
                                counts: data.counts || {},
                                customColumns: data.customColumns || []
                            };
                        }
                    }
                    showToast('📂 سرور داده‌ای ندارد، ایجاد پایگاه اولیه...', 'warning');
                    const base = await loadBaseTemplate();
                    // Initial server population
                    await syncDataToServer(base.menuItems, {}, []);
                    return { menuItems: base.menuItems, counts: {}, customColumns: [] };
                } catch (err) {
                    console.error('[API] loadUserMenuData error:', err);
                    showToast('❌ اتصال به سرور برقرار نشد. تلاش برای استفاده از داده محلی.', 'error');
                    try {
                        const base = await loadBaseTemplate();
                        return { menuItems: base.menuItems, counts: {}, customColumns: [] };
                    } catch (e) {
                        return null;
                    }
                }
            }

            // Sync changes to server using POST/PUT/DELETE
            async function syncDataToServer(menuData, countsMap, customCols) {
                const originalIds = originalMenuData.map(item => item.serviceNameId);
                const currentIds = menuData.map(item => item.serviceNameId);

                const addedItems = menuData.filter(item => !originalIds.includes(item.serviceNameId));
                const deletedIds = originalIds.filter(id => !currentIds.includes(id));
                const editedItems = menuData.filter(item => {
                    if (addedItems.includes(item)) return false;
                    const originalItem = originalMenuData.find(oi => oi.serviceNameId === item.serviceNameId);
                    if (!originalItem) return false;
                    // Check if any field changed or count changed
                    const fieldsChanged = Object.keys(item).some(key => {
                        if (key === 'serviceNameId' || key === 'id') return false;
                        return item[key] !== originalItem[key];
                    });
                    const countChanged = (countsMap[item.serviceNameId] || 0) !== (originalCountsMap[item.serviceNameId] || 0);
                    return fieldsChanged || countChanged || unsavedStats.editedRows.has(item.serviceNameId);
                });

                console.log([API] Sync: ${addedItems.length} added, ${editedItems.length} edited, ${deletedIds.length} deleted);

                // Process additions
                for (const item of addedItems) {
                    const payload = { ...item, count: countsMap[item.serviceNameId] || 0 };
                    console.log([API] POST /menu, payload);
                    try {
                        const res = await fetch(${API_BASE}/menu, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        if (!res.ok) throw new Error(await res.text());
                        console.log('[API] POST success');
                    } catch (e) {
                        console.error('[API] POST failed:', e);
                        throw new Error('افزودن آیتم ناموفق: ' + e.message);
                    }
                }

                // Process edits
                for (const item of editedItems) {
                    const payload = { ...item, count: countsMap[item.serviceNameId] || 0 };
                    console.log([API] PUT /menu/${item.serviceNameId}, payload);
                    try {
                        const res = await fetch(${API_BASE}/menu/${encodeURIComponent(item.serviceNameId)}, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        if (!res.ok) throw new Error(await res.text());
                        console.log('[API] PUT success');
                    } catch (e) {
                        console.error('[API] PUT failed:', e);
                        throw new Error('ویرایش آیتم ناموفق: ' + e.message);
                    }
                }

                // Process deletions
                for (const id of deletedIds) {
                    console.log([API] DELETE /menu/${id});
                    try {
                        const res = await fetch(${API_BASE}/menu/${encodeURIComponent(id)}, { method: 'DELETE' });
                        if (!res.ok) throw new Error(await res.text());
                        console.log('[API] DELETE success');
                    } catch (e) {
                        console.error('[API] DELETE failed:', e);
                        throw new Error('حذف آیتم ناموفق: ' + e.message);
                    }
                }

                // Custom columns remain in localStorage
                saveToLS('customColumns', customCols);
                return true;
            }

            // Save to server and update originals
            async function saveDataToServer() {
                try {
                    await syncDataToServer(currentMenuData, currentCountsMap, customColumns);
                    // After successful sync, reload latest data from server to ensure consistency
                    const fresh = await loadUserMenuData();
                    if (fresh) {
                        currentMenuData = fresh.menuItems;
                        currentCountsMap = fresh.counts;
                        customColumns = fresh.customColumns;
                    }
                    clearUnsaved();
                    return true;
                } catch (err) {
                    console.error('[API] saveDataToServer failed:', err);
                    showToast('❌ ذخیره‌سازی روی سرور ناموفق بود: ' + err.message, 'error');
                    throw err;
                }
            }

            const allColumnDefs = [
                { key: 'ردیف', label: 'ردیف', dataField: 'ردیف', editable: false, dateColumn: false,
                    defaultWidth: 55, minWidth: 35 },
                { key: 'روز تولید', label: 'روز تولید', dataField: null, editable: false, dateColumn: true,
                    dateType: 'day', defaultWidth: 85, minWidth: 35 },
                { key: 'تاریخ تولید', label: 'تاریخ تولید', dataField: null, editable: false, dateColumn: true,
                    dateType: 'date', defaultWidth: 105, minWidth: 35 },
                { key: 'روز پروازی', label: 'روز پروازی', dataField: null, editable: false, dateColumn: true,
                    dateType: 'flightDay', defaultWidth: 85, minWidth: 35 },
                { key: 'تاریخ پروازی', label: 'تاریخ پروازی', dataField: null, editable: false, dateColumn: true,
                    dateType: 'flightDate', defaultWidth: 105, minWidth: 35 },
                { key: 'شرح سرویس منو', label: 'شرح سرویس منو', dataField: 'شرح سرویس منو', editable: true,
                    defaultWidth: 195, minWidth: 35 },
                { key: 'نوع پک غذا', label: 'نوع پک غذا', dataField: 'نوع پک غذا', editable: true, defaultWidth: 175,
                    minWidth: 35 },
                { key: 'کد محصول پک', label: 'کد محصول پک', dataField: 'کد محصول پک', editable: true, defaultWidth: 115,
                    minWidth: 35 },
                { key: 'نوع سرویس نفرات', label: 'نوع سرویس نفرات', dataField: 'نوع سرویس نفرات', editable: true,
                    defaultWidth: 120, minWidth: 35 },
                { key: 'کد محصول رسپی', label: 'کد محصول رسپی', dataField: 'کد محصول رسپی', editable: true,
                    defaultWidth: 110, minWidth: 35 },
                { key: 'نوع سرویس رسپی', label: 'نوع سرویس رسپی', dataField: 'نوع سرویس رسپی', editable: true,
                    defaultWidth: 130, minWidth: 35 },
                { key: 'جمع کل', label: 'جمع کل', dataField: 'جمع کل', editable: true, isCount: true, defaultWidth: 85,
                    minWidth: 35 },
                { key: 'واحد تولیدی', label: 'واحد تولیدی', dataField: 'واحد تولیدی', editable: true, defaultWidth: 125,
                    minWidth: 35 },
                { key: 'مخفف سرویس', label: 'مخفف سرویس', dataField: 'مخفف سرویس', editable: true, defaultWidth: 115,
                    minWidth: 35 }
            ];

            const actionColumnDef = { key: 'actions', label: 'حذف', dataField: null, editable: false, actionColumn: true,
                defaultWidth: 50, minWidth: 40 };

            const LS_PREFIX = 'flightMenu_v2_';

            let currentMenuData = [];
            let currentCountsMap = {};
            let sortState = { column: null, direction: null };
            let searchQuery = '';
            let currentProductionDate = new Date();
            let currentFlightDate = new Date(currentProductionDate.getTime() + 86400000);
            let editMode = false;
            let columnWidths = {};
            let visibleColumns = [];
            let isResizing = false;
            let resizeColIndex = null;
            let resizeStartX = 0;
            let resizeStartWidth = 0;
            let draggedColumnKey = null;
            let activeFilters = {};
            let filterRowVisible = false;
            let availableFilterValues = {};
            let customColumns = [];

            function getAllColumnDefs() {
                const baseDefs = [...allColumnDefs];
                const customDefs = customColumns.map(cc => ({
                    key: cc.key,
                    label: cc.label,
                    dataField: cc.dataField || cc.key,
                    editable: true,
                    dateColumn: false,
                    isCount: false,
                    isCustom: true,
                    columnType: cc.type || 'text',
                    defaultWidth: cc.defaultWidth || 150,
                    minWidth: cc.minWidth || 50
                }));
                return [...baseDefs, ...customDefs];
            }

            function saveToLS(key, value) {
                try {
                    localStorage.setItem(LS_PREFIX + key, JSON.stringify(value));
                } catch (e) {
                    if (e.name === 'QuotaExceededError') {
                        showToast('⚠️ فضای ذخیره‌سازی پر است.', 'error');
                    }
                }
            }

            function loadFromLS(key, defaultValue) {
                try { const raw = localStorage.getItem(LS_PREFIX + key); return raw !== null ? JSON.parse(raw) : defaultValue; } catch (e) { return defaultValue; }
            }

            async function saveUiState() {
                saveToLS('visibleColumns', visibleColumns);
                saveToLS('colWidths', columnWidths);
                saveToLS('sortState', sortState);
                saveToLS('searchQuery', searchQuery);
                saveToLS('editMode', editMode);
                saveToLS('prodDate', toPersianDateStr(currentProductionDate));
                saveToLS('activeFilters', activeFilters);
                saveToLS('filterRowVisible', filterRowVisible);
            }

            async function saveData() {
                await saveDataToServer();
                await saveUiState();
            }

            async function loadData(serverData) {
                if (!menuDatabase) return;
                if (serverData) {
                    currentMenuData = serverData.menuItems;
                    currentCountsMap = serverData.counts || {};
                    customColumns = serverData.customColumns || [];
                } else {
                    currentMenuData = JSON.parse(JSON.stringify(menuDatabase.menuItems));
                    currentCountsMap = {};
                    customColumns = [];
                }
                // Set originals
                originalMenuData = JSON.parse(JSON.stringify(currentMenuData));
                originalCountsMap = { ...currentCountsMap };

                const allCols = getAllColumnDefs();
                visibleColumns = loadFromLS('visibleColumns', null);
                if (!visibleColumns || !Array.isArray(visibleColumns) || visibleColumns.length === 0) {
                    visibleColumns = allCols.map(c => c.key);
                }
                columnWidths = loadFromLS('colWidths', {});
                sortState = loadFromLS('sortState', { column: null, direction: null });
                searchQuery = loadFromLS('searchQuery', '');
                document.getElementById('searchInput').value = searchQuery;
                editMode = loadFromLS('editMode', false);
                activeFilters = loadFromLS('activeFilters', {});
                filterRowVisible = loadFromLS('filterRowVisible', false);
                const savedDate = loadFromLS('prodDate', null);
                if (savedDate) {
                    const d = persianStrToDate(savedDate);
                    if (d && !isNaN(d.getTime())) {
                        currentProductionDate = d;
                        currentFlightDate = new Date(d.getTime() + 86400000);
                    }
                }
                allCols.forEach(col => {
                    if (!columnWidths[col.key] || columnWidths[col.key] < col.minWidth) {
                        columnWidths[col.key] = col.defaultWidth;
                    }
                });
                if (!columnWidths['actions']) columnWidths['actions'] = actionColumnDef.defaultWidth;
                customColumns.forEach(cc => {
                    currentMenuData.forEach(item => {
                        if (!(cc.dataField in item)) {
                            item[cc.dataField] = null;
                        }
                    });
                });
                clearUnsaved();
            }

            async function resetToOriginalData() {
                if (confirm('⚠️ آیا از بازگردانی به اطلاعات اولیه اطمینان دارید؟ تمام تغییرات کاربر حذف می‌شود.')) {
                    currentMenuData = JSON.parse(JSON.stringify(menuDatabase.menuItems));
                    currentCountsMap = {};
                    customColumns = [];
                    activeFilters = {};
                    filterRowVisible = false;
                    clearUnsaved();
                    await saveData();
                    renderFullTable();
                    showToast('🔄 اطلاعات اولیه بازیابی شد.');
                }
            }

            function toPersianDateStr(date) {
                const j = jalaali.toJalaali(date.getFullYear(), date.getMonth() + 1, date.getDate());
                return ${j.jy}/${String(j.jm).padStart(2,'0')}/${String(j.jd).padStart(2,'0')};
            }

            function getPersianWeekday(date) {
                const days = ['یکشنبه', 'دوشنبه', 'سه‌شنبه', 'چهارشنبه', 'پنج‌شنبه', 'جمعه', 'شنبه'];
                return days[date.getDay()];
            }

            function persianStrToDate(str) {
                const parts = str.split('/');
                if (parts.length !== 3) return null;
                const jy = parseInt(parts[0]),
                    jm = parseInt(parts[1]),
                    jd = parseInt(parts[2]);
                if (isNaN(jy) || isNaN(jm) || isNaN(jd)) return null;
                try { const g = jalaali.toGregorian(jy, jm, jd); return new Date(g.gy, g.gm - 1, g.gd); } catch (e) { return null; }
            }

            function parsePersianNumber(str) {
                if (!str) return NaN;
                const persianDigits = '۰۱۲۳۴۵۶۷۸۹';
                let normalized = '';
                for (let ch of str) {
                    const idx = persianDigits.indexOf(ch);
                    if (idx >= 0) normalized += idx;
                    else if (ch >= '0' && ch <= '9') normalized += ch;
                    else if (ch === ',' || ch === '،') continue;
                    else if (ch === '-') normalized += '-';
                }
                return parseFloat(normalized);
            }

            function showToast(msg, type = 'success') {
                const t = document.getElementById('toast');
                t.textContent = toPersianDigits(msg);
                t.className = 'toast ' + type;
                clearTimeout(window.toastTimer);
                requestAnimationFrame(() => t.classList.add('show'));
                window.toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
            }

            function setStatus(msg, err = false) {
                const el = document.getElementById('logStatus');
                el.textContent = msg;
                el.style.color = err ? 'var(--danger)' : 'var(--success)';
            }

            function getVisibleColumnsDefs() {
                const allCols = getAllColumnDefs();
                const cols = [];
                visibleColumns.forEach(key => {
                    const colDef = allCols.find(c => c.key === key);
                    if (colDef) cols.push(colDef);
                });
                cols.push(actionColumnDef);
                return cols;
            }

            function buildAvailableFilterValues() {
                availableFilterValues = {};
                const allCols = getAllColumnDefs().filter(c => !c.dateColumn && c.key !== 'ردیف' && c.key !== 'جمع کل' && c.key !== 'actions');
                allCols.forEach(col => {
                    const valSet = new Set();
                    currentMenuData.forEach(item => {
                        const val = item[col.dataField];
                        if (val !== null && val !== undefined && val !== '') {
                            valSet.add(String(val).trim());
                        }
                    });
                    availableFilterValues[col.key] = [...valSet].sort((a, b) => a.localeCompare(b, 'fa'));
                });
            }

            function renderFullTable() {
                const container = document.getElementById('tableContainer');
                const visibleDefs = getVisibleColumnsDefs();
                const filtered = getFilteredSortedItems();

                document.getElementById('rowCountBadge').textContent =
                    📋 ${toPersianDigits(filtered.length.toLocaleString('en-US'))} از ${toPersianDigits(currentMenuData.length.toLocaleString('en-US'))} ردیف;

                if (!filtered.length) { container.innerHTML = '<div class="empty-message">🔍 هیچ ردیفی یافت نشد.</div>'; return; }

                const prodDay = getPersianWeekday(currentProductionDate);
                const prodDate = toPersianDateStr(currentProductionDate);
                const flightDay = getPersianWeekday(currentFlightDate);
                const flightDate = toPersianDateStr(currentFlightDate);

                document.getElementById('printProdDate').textContent = toPersianDigits(prodDate);
                document.getElementById('printProdDay').textContent = prodDay;
                document.getElementById('printFlightDate').textContent = toPersianDigits(flightDate);
                document.getElementById('printFlightDay').textContent = flightDay;

                let colgroup = '<colgroup>';
                visibleDefs.forEach(col => {
                    const w = columnWidths[col.key] || col.defaultWidth;
                    colgroup += <col style="width:${Math.max(w, col.minWidth || 5)}px;">;
                });
                colgroup += '</colgroup>';

                let thead = '<thead>';
                thead += '<tr>';
                visibleDefs.forEach((col, idx) => {
                    let classes = col.actionColumn ? '' : 'sortable';
                    let icon = ' ⇅';
                    if (sortState.column === col.key && !col.actionColumn) {
