            window.filterIntegration = { getActiveFilters: function() { return { ...activeFilters }; }, setActiveFilters: function(filters) { activeFilters = { ...filters }; saveUiState(); renderFullTable(); }, clearAllFilters: function() { activeFilters = {}; saveUiState(); renderFullTable(); }, getAvailableFilterValues: function() { return { ...availableFilterValues }; } };
