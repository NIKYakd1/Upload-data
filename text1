فایل from http.server import BaseHTTPRequestHandler, HTTPServer
import json

HOST = "localhost"
PORT = 9000

class ApiHandler(BaseHTTPRequestHandler):

    def do_GET(self):

        if self.path == "/users":

            with open(
                "USERDATA.json",
                "r",
                encoding="utf-8"
            ) as f:

                data = json.load(f)

            self.send_response(200)
            self.send_header(
                "Content-type",
                "application/json"
            )
            self.end_headers()

            self.wfile.write(
                json.dumps(data).encode("utf-8")
            )

            return

        if self.path == "/menu":

            with open(
                "DataMn.json",
                "r",
                encoding="utf-8"
            ) as f:

                data = json.load(f)

            self.send_response(200)
            self.send_header(
                "Content-type",
                "application/json"
            )
            self.end_headers()

            self.wfile.write(
                json.dumps(data).encode("utf-8")
            )

            return

server = HTTPServer(
    (HOST, PORT),
    ApiHandler
)

print(
    f"API Running: http://{HOST}:{PORT}"
)

server.serve_forever()

